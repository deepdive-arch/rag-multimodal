APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-multimodal
PINECONE_NAMESPACE=default

GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_GENERATION_MODEL=gemini-3.5-flash
EMBEDDING_DIMENSION=1536

CHUNK_SIZE=1500
CHUNK_OVERLAP=250
MIN_CHUNK_SIZE=100
TEXT_PREVIEW_SIZE=400

DEFAULT_TOP_K=5
MAX_TOP_K=20
MIN_RELEVANCE_SCORE=0.35
MAX_MATCHES_PER_DOCUMENT=3
MAX_MEDIA_PARTS_PER_QUERY=3
MAX_CHAT_HISTORY_MESSAGES=6

MAX_UPLOAD_SIZE_MB=100
MAX_PDF_PAGES=200
MAX_AUDIO_DURATION_SECONDS=180
MAX_VIDEO_DURATION_SECONDS=120

UPLOADS_DIR=.tmp/uploads
DERIVED_DIR=.tmp/uploads/derived
DATABASE_PATH=.tmp/rag.db

ADMIN_TOKEN=
LOG_LEVEL=INFO
