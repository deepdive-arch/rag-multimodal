    { "dot": "cyan", "title": "Common controls", "items": ["MIME, extensão, assinatura, tamanho, SHA-256 e quotas são validados", "Original é persistido no R2 antes do processamento", "Falhas acionam rollback best-effort e estado retryable"] },
    { "dot": "violet", "title": "Modality paths", "items": ["PDF usa texto quando disponível e renderiza página escaneada para PNG", "DOCX lê parágrafos, headings e tabelas; TXT/Markdown viram chunks", "Imagens, áudio e vídeo são validados como itens multimodais; vídeo não indexa áudio interno"] },
    { "dot": "rose", "title": "Persistence contract", "items": ["Vetores são upsertados no Pinecone antes do catálogo virar ready", "Postgres mantém referências de objetos e chunks para validar fontes", "O workspace local é descartado no finally; não é armazenamento persistente"] }
